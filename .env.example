NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# -----------------------------------------------------------------------------
# Database (local host mode)
# When API runs on your machine, connect via localhost:6432 (PgBouncer)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://medsys:medsys@localhost:6432/medsys
DATABASE_READ_URL=postgres://medsys:medsys@localhost:6432/medsys
DATABASE_USER=medsys
DATABASE_PASSWORD=medsys

# -----------------------------------------------------------------------------
# Optional infra services
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_PATIENT_INDEX=medsys_patients
OPENSEARCH_DIAGNOSIS_INDEX=medsys_diagnoses

# -----------------------------------------------------------------------------
# External terminology providers
# -----------------------------------------------------------------------------
ICD10_API_BASE_URL=https://clinicaltables.nlm.nih.gov/api/icd10cm/v3/search
LOINC_API_BASE_URL=https://clinicaltables.nlm.nih.gov/api/loinc_items/v3/search

# -----------------------------------------------------------------------------
# Audit pipeline
# -----------------------------------------------------------------------------
AUDIT_TRANSPORT=auto
AUDIT_QUEUE_KEY=medsys:audit:events
AUDIT_RETRY_QUEUE_KEY=medsys:audit:events:retry
AUDIT_DLQ_KEY=medsys:audit:events:dlq
AUDIT_MAX_RETRIES=3
AUDIT_RETRY_BASE_DELAY_MS=250
AUDIT_WORKER_BLOCK_SECONDS=5

# -----------------------------------------------------------------------------
# Cache tuning
# -----------------------------------------------------------------------------
APPOINTMENT_QUEUE_CACHE_TTL_SECONDS=15
PATIENT_PROFILE_CACHE_TTL_SECONDS=30

# -----------------------------------------------------------------------------
# Security + auth
# -----------------------------------------------------------------------------
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_SECONDS=300
SECURITY_SENSITIVE_WINDOW_SECONDS=3600

# Use PEM values. New lines can be escaped as \n in .env.
JWT_ACCESS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----
JWT_ACCESS_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----
JWT_REFRESH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----
JWT_REFRESH_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
REQUEST_ID_HEADER=x-request-id

# Default seeded tenant/org for local development
ORGANIZATION_ID=11111111-1111-1111-1111-111111111111

# Optional
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# -----------------------------------------------------------------------------
# Frontend repo (.env.local) template values
# Copy these into your FE repo env file and adjust to your FE framework.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/v1
# VITE_API_BASE_URL=http://localhost:8080/v1
